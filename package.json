{
  "name": "t-employ",
  "version": "0.1.0",
  "description": "TBELL Employ - 채용 지원자/인재검색 통합 수집 및 관리 시스템",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/db/migrate.ts up",
    "db:status": "tsx src/db/migrate.ts status",
    "db:seed": "tsx src/db/seed.ts",
    "db:dump": "tsx src/db/persist.ts dump",
    "db:restore": "tsx src/db/persist.ts restore",
    "db:supabase": "tsx src/db/applySupabase.ts",
    "crawl:applicants": "tsx src/jobs/crawlApplicants.ts",
    "poll:applicants": "tsx src/jobs/pollApplicants.ts",
    "crawl:talent": "tsx src/jobs/crawlTalentPool.ts",
    "session:refresh": "tsx src/jobs/refreshSession.ts",
    "pdf:applicants": "tsx src/jobs/fetchMissingApplicantPdfs.ts",
    "pdf:talents": "tsx src/tools/fetchTalentPdfs.ts",
    "ops:health": "tsx src/jobs/healthCheck.ts",
    "report:compose": "tsx src/jobs/composeDailyReport.ts",
    "mail:send": "tsx src/jobs/sendDailyMail.ts",
    "mail:morning-digest": "tsx src/jobs/sendMorningDigest.ts",
    "dev:check": "tsx src/tools/routeCheck.ts",
    "dev:login": "tsx src/tools/loginCheck.ts",
    "dev:session": "tsx src/tools/loginCheck.ts --wait-2fa",
    "dev:crawl-stats": "tsx src/tools/crawlStats.ts",
    "dev:verify-merge": "tsx src/tools/verifyMerge.ts",
    "dev:collab-check": "tsx src/tools/collabVerify.ts",
    "dev:mail-test": "tsx src/tools/mailTest.ts",
    "dev:fetch-pdfs": "tsx src/tools/fetchApplicantPdfs.ts",
    "dev:fetch-talent-pdfs": "tsx src/tools/fetchTalentPdfs.ts",
    "dev:probe-api": "tsx src/tools/probeApplicantApi.ts",
    "collab": "tsx src/tools/collabCli.ts",
    "notify:action": "tsx src/jobs/notifyActionResult.ts",
    "web:serve": "npx --yes serve web -p 5173",
    "web:config": "tsx src/tools/writeWebConfig.ts"
  },
  "keywords": [
    "recruiting",
    "crawler",
    "playwright",
    "postgres"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "cheerio": "^1.2.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
