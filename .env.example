# ===========================================================================
# TBELL Employ - 환경변수 예시 (.env로 복사 후 값 채우기)
# 실제 .env 파일은 절대 커밋하지 않는다 (.gitignore 처리됨)
# ===========================================================================

# --- Database ---
# 기본: DATABASE_URL 을 비워두면 임베디드 Postgres(PGlite)를 사용한다.
#       계정/Docker/설치 없이 data/pgdata 파일에 저장된다.
# 임베디드 DB 파일 위치 (기본값 data/pgdata)
PGLITE_DIR=data/pgdata

# 호스티드 Postgres 로 전환하려면 아래 주석을 풀고 접속 문자열을 넣는다 (코드 변경 불필요).
# DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# PGSSL=true

# --- Supabase (인터랙티브 웹 UI: 로그인/태그/면접/삭제상태) ---
# 설정 방법: docs/develop/supabase-setup.md
# SUPABASE_URL, SUPABASE_ANON_KEY 는 브라우저에서 사용(공개 가능), service_role 은 서버 전용(비공개)
# SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- 세션 암호화 키 (storageState 암호화, 32bytes hex 권장) ---
SESSION_ENC_KEY=change-me-32-bytes-hex-key

# --- 잡코리아 기업계정 ---
JOBKOREA_USERNAME=
JOBKOREA_PASSWORD=
JOBKOREA_TOTP_SECRET=

# --- 사람인 기업계정 ---
SARAMIN_USERNAME=
SARAMIN_PASSWORD=
SARAMIN_TOTP_SECRET=

# --- 메일 발송 (일일 요약) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@tbell.co.kr
# 쉼표로 구분된 수신자 목록
DAILY_REPORT_RECIPIENTS=

# --- 크롤러 실행 옵션 ---
# headless=true 로 CI 실행, 로컬 디버깅 시 false
HEADLESS=true
# 크롤 단계별 스크린샷 저장 여부
CAPTURE_SCREENSHOTS=true
