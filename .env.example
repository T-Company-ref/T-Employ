# ===========================================================================
# TBELL Employ - 환경변수 예시 (.env로 복사 후 값 채우기)
# 실제 .env 파일은 절대 커밋하지 않는다 (.gitignore 처리됨)
# ===========================================================================

# --- Database ---
# 기본: DATABASE_URL 을 비워두면 임베디드 Postgres(PGlite)를 사용한다.
#       계정/Docker/설치 없이 data/pgdata 파일에 저장된다.
# 임베디드 DB 파일 위치 (기본값 data/pgdata)
PGLITE_DIR=data/pgdata

# 호스티드 Postgres 로 전환하려면 아래 주석을 풀고 접속 문자열을 넣는다 (코드 변경 불필요).
# DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# PGSSL=true

# --- Supabase (인터랙티브 웹 UI: 로그인/태그/면접/삭제상태) ---
# 설정 방법: docs/develop/supabase-setup.md , docs/develop/web-ui.md
SUPABASE_URL=https://koxsezeotvylkeqeixnb.supabase.co
SUPABASE_ANON_KEY=
# PDF 업로드용 (웹 다운로드). GitHub Secret에도 동일 키 등록
SUPABASE_SERVICE_ROLE_KEY=

# --- 세션 암호화 키 (storageState 암호화, 32bytes hex 권장) ---
SESSION_ENC_KEY=change-me-32-bytes-hex-key

# --- 잡코리아 기업계정 ---
JOBKOREA_USERNAME=
JOBKOREA_PASSWORD=
JOBKOREA_TOTP_SECRET=

# --- 사람인 기업계정 ---
SARAMIN_USERNAME=
SARAMIN_PASSWORD=
SARAMIN_TOTP_SECRET=

# --- 메일 발송 (Gmail SMTP — @gmail.com 발신) ---
GMAIL_USER=tbell.wr@gmail.com
GMAIL_APP_PASSWORD=
MAIL_FROM=T-Employ <tbell.wr@gmail.com>

# --- Resend (tbell.co.kr 도메인 인증 후 사용, Gmail 대신) ---
# RESEND_API_KEY=
# RESEND_FROM=T-Employ <noreply@tbell.co.kr>
# 일일 요약 수신자 (미설정 시 yj.kim@tbell.co.kr 기본 포함)
DAILY_REPORT_RECIPIENTS=
# Actions 실행 결과 알림 (미설정 시 yj.kim@tbell.co.kr 기본 포함)
ACTION_NOTIFY_EMAIL=

# --- 크롤러 실행 옵션 ---
# headless=true 로 CI 실행, 로컬 디버깅 시 false
HEADLESS=true
# 크롤 단계별 스크린샷 저장 여부
CAPTURE_SCREENSHOTS=true
# 플랫폼당 1회 수집 상한 (Phase 1 기본 20)
CRAWL_MAX_ITEMS=20
# 로컬 기본 false (CI 크롤 워크플로는 true). 스케줄 시뮬레이션: GITHUB_EVENT_NAME=schedule
AUTO_CRAWL_ENABLED=false
# 크롤 시 상세 진입 후 이력서 PDF 수집 (Supabase Storage 업로드 — SERVICE_ROLE_KEY 필요)
CRAWL_FETCH_RESUMES=true
# PDF(page.pdf)는 headless Chromium 전용. FETCH_RESUMES 시 headless 강제됨
# set GITHUB_EVENT_NAME=schedule && set AUTO_CRAWL_ENABLED=true
# npm run crawl:applicants jobkorea
