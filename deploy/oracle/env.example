# TBELL Employ — Oracle Always Free 배포용 환경 변수 예시
# 복사: cp deploy/oracle/env.example /opt/t-employ/.env
# 값은 Git에 올리지 말 것.

# --- DB (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres:CHANGE_ME@db.XXXX.supabase.co:5432/postgres
PGSSL=true

# --- JobKorea ---
JOBKOREA_USERNAME=
JOBKOREA_PASSWORD=

# --- (선택) 사람인 — Phase C에서는 미사용 ---
# SARAMIN_USERNAME=
# SARAMIN_PASSWORD=

# --- Browser ---
HEADLESS=true
CAPTURE_SCREENSHOTS=false
CRAWL_FETCH_RESUMES=true
CRAWL_MAX_ITEMS=50
TALENT_CRAWL_MAX_ITEMS=5
PDF_MAX_ITEMS=15

# --- Oracle 스케줄 필수 ---
AUTO_CRAWL_ENABLED=true

# --- Mail ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM="T-Employ" <noreply@example.com>
# ACTION_NOTIFY_EMAIL=yj.kim@tbell.co.kr

# --- Supabase Storage (PDF) ---
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
