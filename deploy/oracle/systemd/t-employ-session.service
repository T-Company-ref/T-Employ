[Unit]
Description=TBELL Employ — session refresh (Playwright)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/default/t-employ
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/t-employ
Nice=10
TimeoutStartSec=600
ExecStart=/usr/local/bin/t-employ-run session:refresh -- jobkorea
