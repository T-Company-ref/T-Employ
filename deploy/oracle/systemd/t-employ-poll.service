[Unit]
Description=TBELL Employ — poll applicants (fetch HTML)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-/etc/default/t-employ
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/t-employ
Nice=5
TimeoutStartSec=900
ExecStart=/usr/local/bin/t-employ-run poll:applicants
